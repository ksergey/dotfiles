/*
 * GTK Colors - Generated with Matugen
 * This file is overwritten when you change wallpaper
 */

@define-color accent_color #f1eeff;
@define-color accent_fg_color #000000;
@define-color accent_bg_color #f1eeff;

@define-color window_bg_color #131318;
@define-color window_fg_color #e4e1e9;

@define-color headerbar_bg_color #131318;
@define-color headerbar_fg_color #ffffff;

@define-color popover_bg_color #131318;
@define-color popover_fg_color #ffffff;

@define-color view_bg_color #131318;
@define-color view_fg_color #ffffff;

@define-color card_bg_color #131318;
@define-color card_fg_color #ffffff;

@define-color sidebar_bg_color @window_bg_color;
@define-color sidebar_fg_color @window_fg_color;
@define-color sidebar_border_color @window_bg_color;
@define-color sidebar_backdrop_color @window_bg_color;

/* Nautilus sidebar */
.nautilus-window .sidebar,
.nautilus-window sidebar,
.nautilus-window placessidebar,
.nautilus-window placessidebar list,
placessidebar,
placessidebar list {
    background-color: #131318 !important;
    color: #e4e1e9 !important;
}

placessidebar row {
    background-color: transparent !important;
    color: #e4e1e9 !important;
}

placessidebar row:hover {
    background-color: alpha(#f1eeff, 0.1) !important;
}

placessidebar row:selected,
placessidebar row:selected:hover {
    background-color: #f1eeff !important;
    color: #000000 !important;
}

.nautilus-window headerbar {
    background-color: #131318 !important;
    color: #e4e1e9 !important;
}

.nautilus-window .view {
    background-color: #131318 !important;
    color: #e4e1e9 !important;
}

placessidebar image {
    color: #e4e1e9 !important;
}

placessidebar row:selected image {
    color: #000000 !important;
}