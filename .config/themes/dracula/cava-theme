[general]
framerate    = 60
autosens     = 1
sensitivity  = 100
bars         = 0
bar_width    = 2
bar_spacing  = 1

[input]
method = pipewire
source = auto

[output]
method   = noncurses
channels = stereo
orientation = bottom

[color]
background = default
foreground = '#f8f8f2'

[smoothing]
monstercat    = 1
waves         = 0
noise_reduction = 60

[eq]
1 = 1.2   # boost bass slightly
2 = 1.0
3 = 0.9   # slight mid cut
4 = 1.0
5 = 1.1   # slight treble boost
